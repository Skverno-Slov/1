Шаг 5.1: Создание gRPC-сервисаСоздайте новый проект в Visual Studio или через CLI по шаблону gRPC Service:bashdotnet new grpc -n OrderGrpcService
Используйте код с осторожностью.5.1.1 Создание proto-файла (order.proto)В папке Protos замените содержимое файла greet.proto или создайте новый файл order.proto:protobufsyntax = "proto3";

option csharp_namespace = "OrderGrpcService";

import "google/protobuf/timestamp.proto";
import "google/protobuf/empty.proto";

package order;

service OrderService {
  rpc CreateOrder (CreateOrderRequest) returns (OrderResponse);
  rpc GetOrder (GetOrderRequest) returns (OrderResponse);
  rpc UpdateOrder (UpdateOrderRequest) returns (OrderResponse);
  rpc DeleteOrder (DeleteOrderRequest) returns (google.protobuf.Empty);
  rpc ListOrders (google.protobuf.Empty) returns (OrderListResponse);
  // Метод для шага 5.3
  rpc FilterOrders (FilterOrdersRequest) returns (OrderListResponse);
}

message Product {
  string name = 1;
  double price = 2;
}

message OrderResponse {
  string id = 1;
  google.protobuf.Timestamp order_date = 2;
  repeated Product products = 3;
}

message CreateOrderRequest {
  repeated Product products = 1;
}

message GetOrderRequest {
  string id = 1;
}

message UpdateOrderRequest {
  string id = 1;
  repeated Product products = 2;
}

message DeleteOrderRequest {
  string id = 1;
}

message OrderListResponse {
  repeated OrderResponse orders = 1;
}

message FilterOrdersRequest {
  google.protobuf.Timestamp start_date = 1;
  double min_price = 2;
}
