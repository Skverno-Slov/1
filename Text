Используйте код с осторожностью.5.2.2 и 5.3.1 Создание интерфейса API (ForumApiService)Объединяем функции получения, фильтрации и отправки данных (из пунктов 5.2, 5.3, 5.4):kotlinimport retrofit2.http.Body
import retrofit2.http.GET
import retrofit2.http.POST
import retrofit2.http.Path
import retrofit2.http.Query

interface ForumApiService {
    // 5.2.2 Получение всех постов
    @GET("posts")
    suspend fun getPosts(): List<Post>

    // 5.3.1 Получение комментариев по ID поста (используя Query или Path в зависимости от структуры API)
    // Если API требует /posts/{postId}/comments, используем @Path:
    @GET("posts/{postId}/comments")
    suspend fun getCommentsByPostId(@Path("postId") postId: Int): List<Comment>
    
    // Альтернатива, если API использует Query параметры вроде /comments?postId=1:
    @GET("comments")
    suspend fun getCommentsByQuery(@Query("postId") postId: Int): List<Comment>

    // 5.4.1 Создание нового поста
    @POST("posts")
    suspend fun createPost(@Body post: Post): Post

    // 5.4.3 Создание нового комментария
    @POST("comments")
    suspend fun createComment(@Body comment: Comment): Comment
}
