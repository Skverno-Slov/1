import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import kotlinx.coroutines.launch

class ForumViewModel : ViewModel() {
    var posts = mutableStateOf<List<Post>>(emptyList())
    var commentsMap = mutableStateOf<Map<Int, List<Comment>>>(emptyMap()) // Хранение комментариев для каждого поста

    init {
        loadPosts()
    }

    // Загрузка постов (5.2.3 / 5.2.4)
    fun loadPosts() {
        viewModelScope.launch {
            try {
                posts.value = ApiClient.apiService.getPosts()
            } catch (e: Exception) {
                e.printStackTrace()
            }
        }
    }

    // Загрузка комментариев для конкретного поста (5.3.2)
    fun loadCommentsForPost(postId: Int) {
        viewModelScope.launch {
            try {
                val comments = ApiClient.apiService.getCommentsByPostId(postId)
                commentsMap.value = commentsMap.value + (postId to comments)
            } catch (e: Exception) {
                e.printStackTrace()
            }
        }
    }

    // Отправка нового поста (5.4.2)
    fun addNewPost(title: String, body: String, onExpanded: () -> Unit) {
        viewModelScope.launch {
            try {
                val newPost = Post(id = 0, title = title, body = body, userId = 1)
                ApiClient.apiService.createPost(newPost)
                loadPosts() // Обновляем список
                onExpanded()
            } catch (e: Exception) {
                e.printStackTrace()
            }
        }
    }

    // Отправка нового комментария (5.4.4)
    fun addNewComment(postId: Int, name: String, email: String, body: String, onExpanded: () -> Unit) {
        viewModelScope.launch {
            try {
                val newComment = Comment(id = 0, postId = postId, name = name, email = email, body = body)
                ApiClient.apiService.createComment(newComment)
                loadCommentsForPost(postId) // Обновляем комментарии к посту
                onExpanded()
            } catch (e: Exception) {
                e.printStackTrace()
            }
        }
    }
}
