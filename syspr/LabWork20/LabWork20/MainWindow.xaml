<Window x:Class="LabWork20.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork20"
        mc:Ignorable="d"
        Title="MAX: диспетчер задач" Height="450" Width="800">
    
    <Window.Resources>
        <ContextMenu x:Key="ProcessContextMenu">
            <MenuItem Header="Снять задачу" Click="KillTaskMenuItem_Click"/>
        </ContextMenu>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Запустить задачу" Click="NewTaskMenuItem_Click"/>
            <MenuItem Header="Снять задачу" Click="KillTaskMenuItem_Click"/>
            <MenuItem Header="Обновить" Click="Refresh_Click"/>
            <MenuItem Header="Выход" Click="ExitMenuItem_Click"/>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Запущенных процессов: "/>
                    <TextBlock x:Name="StatusProcessCount" Text="0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <TabControl>
            <TabItem Header="Процессы">
                <ListView x:Name="ProcessListView" ContextMenu="{StaticResource ProcessContextMenu}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}" Width="250"/>
                            <GridViewColumn Header="PID" DisplayMemberBinding="{Binding Id}" Width="100"/>
                            <GridViewColumn Header="Память" DisplayMemberBinding="{Binding Memory}" Width="150"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Приложения">
                <ListView x:Name="AppListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Приложение" DisplayMemberBinding="{Binding Title}" Width="400"/>
                            <GridViewColumn Header="Время запуска" DisplayMemberBinding="{Binding StartTime}" Width="200"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
