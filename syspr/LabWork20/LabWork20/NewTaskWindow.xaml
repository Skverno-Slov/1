<Window x:Class="LabWork20.NewTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork20"
        mc:Ignorable="d"
        Title="Запуск процесса" Height="450" Width="800">
    
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ОК" Width="75" Margin="0,0,5,0" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="75" Click="CancelButton_Click"/>
        </StackPanel>

        <DockPanel VerticalAlignment="Center">
            <Button Content="Обзор..." DockPanel.Dock="Right" Width="75" Margin="5,0,0,0" Click="BrowseButton_Click"/>
            <TextBox x:Name="PathTextBox"/>
        </DockPanel>
    </DockPanel>
</Window>
