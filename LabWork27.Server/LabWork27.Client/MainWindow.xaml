<Window x:Class="LabWork27.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabWork27.Client"
        mc:Ignorable="d"
        Title="Max" Height="450" Width="800">
    <StackPanel>
        <StackPanel x:Name="LoginPanel" VerticalAlignment="Center" Visibility="Visible">
            <TextBlock Text="Имя"/>
            <TextBox x:Name="UserNameInput"/>

            <TextBlock Text="Комната"/>
            <TextBox x:Name="RoomNameInput"/>

            <Button Content="Войти" Click="LoginButton_Click"/>
        </StackPanel>

        <StackPanel x:Name="ChatPanel" Visibility="Collapsed">
            <TextBlock x:Name="ChatName" FontWeight="Bold" />

            <ListBox x:Name="MessagesList"/>

            <DockPanel>
                <Button Content="Отправить" Click="SendButton_Click" DockPanel.Dock="Right"/>
                <TextBox x:Name="MessageInput"/>
            </DockPanel>
        </StackPanel>
    </StackPanel>
</Window>
