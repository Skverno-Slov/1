@Composable
fun AnimateAsStateComponent() {
    var isTargetState by remember { mutableStateOf(false) }

    Column(
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Button(onClick = { isTargetState = !isTargetState }) {
            Text("Переключить состояния 5.1")
        }

        // 1. Tween 3s
        val tweenColor by animateColorAsState(
            targetValue = if (isTargetState) Color.Red else Color.Blue,
            animationSpec = tween(durationMillis = 3000), label = ""
        )
        Box(modifier = Modifier.size(80.dp).background(tweenColor), contentAlignment = Alignment.Center) {
            Text("Tween 3s", color = Color.White, fontSize = 12.sp)
        }

        // 2. Keyframes 10s
        val keyframesColor by animateColorAsState(
            targetValue = if (isTargetState) Color.Magenta else Color.Green,
            animationSpec = keyframes {
                durationMillis = 10000
                Color.Yellow at 2500
                Color.Cyan at 5000
                Color.Blue at 7500
            }, label = ""
        )
        Box(modifier = Modifier.size(80.dp).background(keyframesColor), contentAlignment = Alignment.Center) {
            Text("Keyframes 10s", color = Color.White, fontSize = 10.sp)
        }

        // 3. Repeatable 3 times
        val repeatableSize by animateDpAsState(
            targetValue = if (isTargetState) 120.dp else 70.dp,
            animationSpec = repeatable(
                iterations = 3,
                animation = tween(durationMillis = 500),
                repeatMode = RepeatMode.Reverse
            ), label = ""
        )
        Image(
            painter = painterResource(id = R.drawable.square_image),
            contentDescription = "Square Repeatable",
            modifier = Modifier.size(repeatableSize)
        )

        // 4. Spring
        val springSize by animateDpAsState(
            targetValue = if (isTargetState) 120.dp else 70.dp,
            animationSpec = spring(
                dampingRatio = Spring.DampingRatioHighBouncy,
                stiffness = Spring.StiffnessMedium
            ), label = ""
        )
        Image(
            painter = painterResource(id = R.drawable.square_image),
            contentDescription = "Square Spring",
            modifier = Modifier.size(springSize)
        )

        // 5. Infinite Repeatable
        val infiniteColor by animateColorAsState(
            targetValue = if (isTargetState) Color.DarkGray else Color.LightGray,
            animationSpec = infiniteRepeatable(
                animation = tween(durationMillis = 1500),
                repeatMode = RepeatMode.Reverse
            ), label = ""
        )
        Box(modifier = Modifier.size(80.dp).background(infiniteColor), contentAlignment = Alignment.Center) {
            Text("Infinite State", color = Color.Black, fontSize = 12.sp)
        }
    }
}

@Composable
fun AnimatableComponent() {
    var trigger by remember { mutableStateOf(false) }

    val colorAnim = remember { Animatable(Color.Gray) }
    val sizeAnim = remember { Animatable(60.dp, Dp.VectorConverter) }
    val rotateAnim = remember { Animatable(0f) }

    LaunchedEffect(trigger) {
        colorAnim.animateTo(
            targetValue = if (trigger) Color.Cyan else Color.Gray,
            animationSpec = tween(1000)
        )
    }

    LaunchedEffect(trigger) {
        sizeAnim.animateTo(
            targetValue = if (trigger) 120.dp else 60.dp,
            animationSpec = repeatable(
                iterations = 3,
                animation = tween(400),
                repeatMode = RepeatMode.Reverse
            )
        )
    }

    LaunchedEffect(trigger) {
        rotateAnim.animateTo(
            targetValue = if (trigger) 360f else 0f,
            animationSpec = tween(durationMillis = 2000)
        )
    }

    Column(
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Button(onClick = { trigger = !trigger }) {
            Text("Запустить Animatable 5.2")
        }

        Box(modifier = Modifier.size(60.dp).background(colorAnim.value))

        Image(
            painter = painterResource(id = R.drawable.square_image),
            contentDescription = "Round Image",
            modifier = Modifier.size(sizeAnim.value).clip(CircleShape)
        )

        Image(
            painter = painterResource(id = R.drawable.square_image),
            contentDescription = "Rotated Image",
            modifier = Modifier.size(80.dp).graphicsLayer(rotationZ = rotateAnim.value)
        )
    }
}

