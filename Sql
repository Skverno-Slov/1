# Предполагаем, что соединение (conn) и курсор (cursor) уже созданы (из ПР №19)
table_name = input("Введите название таблицы: ")

try:
    # 5.3.1 Выполняем запрос (имя таблицы подставляем f-строкой, т.к. это имя объекта)
    cursor.execute(f"SELECT * FROM {table_name}")
    
    # 5.3.2 Получаем результаты
    results = cursor.fetchall()
    
    # 5.3.3 Построчный вывод названия и цены (предположим, это 1-й и 2-й столбцы)
    print(f"\nСодержимое таблицы {table_name}:")
