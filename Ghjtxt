Part 1: Creating the C++ Dynamic Link Library (DLL)1.1 Project SetupOpen Visual Studio and create a new project.Select Dynamic-Link Library (DLL) for C++. Name it MathLibrary.In the Solution Explorer, select all auto-generated files (dllmain.cpp, pch.cpp, pch.h, framework.h), right-click, and select Remove -> Delete.Right-click the project -> Properties.Navigate to Configuration Properties -> C/C++ -> Precompiled Headers.Change the Precompiled Header setting to Not Using Precompiled Headers. Click Apply.1.2 Writing the CodeRight-click Source Files -> Add -> New Item. Create a file named MathLibrary.cpp. Paste the following code containing the implementations for prime checks, array processing, and coordinate geometry:cpp#include <cmath>

// Define external C linkage to prevent C++ name mangling
extern "C" {

    // Structure for 2D points
    struct Point {
        double X;
        double Y;
    };

    // 5.1.2 & 5.2.1: Check if a number is prime
    __declspec(dllexport) int IsPrime(int number) {
        if (number <= 1) return 0;
        for (int i = 2; i <= std::sqrt(number); ++i) {
            if (number % i == 0) return 0;
        }
        return 1;
    }

    // 5.3: Count prime numbers inside a passed pointer array
    __declspec(dllexport) int CountPrimesInArray(int* arr, int size) {
        if (arr == nullptr || size <= 0) return 0;
        
        int primeCount = 0;
        for (int i = 0; i < size; ++i) {
            if (IsPrime(arr[i]) == 1) {
                primeCount++;
            }
        }
        return primeCount;
    }

    // 5.4: Calculate distance between two Point structures
    __declspec(dllexport) double GetDistance(Point p1, Point p2) {
        return std::sqrt(std::pow(p2.X - p1.X, 2) + std::pow(p2.Y - p1.Y, 2));
    }
}
Используйте код с осторожностью.1.3 Build the DLLSet your build configuration to Release and match your target architecture (e.g., x64).Click Build -> Build Solution.Navigate to your project folder's directory (e.g., MathLibrary/x64/Release/) and locate MathLibrary.dll.Part 2: Creating the C# Console Application2.1 Project SetupIn the same solution (or a new one), create a Console App using C#.Build the C# project once so Visual Studio creates its output directories.Copy the compiled MathLibrary.dll from your C++ folder and paste it directly into your C# project's output directory (e.g., YourCSharpProject/bin/Debug/net8.0/ or bin/Release/).2.2 Writing the C# AppReplace the contents of your Program.cs file with the code below to import the DLL functions using P/Invoke (DllImport) and test them:csharpusing System;
using System.Runtime.InteropServices;

class Program
{
    // Define the matching Point structure layout for 5.4
    [StructLayout(LayoutKind.Sequential)]
    public struct Point
    {
        public double X;
        public double Y;
    }

    // 5.2.3: Import the IsPrime function
    [DllImport("MathLibrary.dll", CallingConvention = CallingConvention.Cdecl)]
    public static extern int IsPrime(int number);

    // 5.3: Import the Array processing function
    [DllImport("MathLibrary.dll", CallingConvention = CallingConvention.Cdecl)]
    public static extern int CountPrimesInArray(int[] arr, int size);

    // 5.4: Import the Structure processing function
    [DllImport("MathLibrary.dll", CallingConvention = CallingConvention.Cdecl)]
    public static extern double GetDistance(Point p1, Point p2);

    static void Main(string[] args)
    {
        Console.WriteLine("=== Testing DLL Integration ===\n");

        // 5.2.4: Test IsPrime
        int testNum = 29;
        int isPrimeResult = IsPrime(testNum);
        Console.WriteLine($"Is {testNum} prime? Result: {isPrimeResult} ({(isPrimeResult == 1 ? "Yes" : "No")})");

        // 5.3: Test Array processing
        int[] numbers = { 4, 7, 10, 13, 17, 20, 23 };
        int primeCount = CountPrimesInArray(numbers, numbers.Length);
        Console.WriteLine($"\nArray: [{string.Join(", ", numbers)}]");
        Console.WriteLine($"Total primes found in array: {primeCount}");

        // 5.4: Test Structures and Distance calculations
        Point pointA = new Point { X = 0.0, Y = 0.0 };
        Point pointB = new Point { X = 3.0, Y = 4.0 };
        double distance = GetDistance(pointA, pointB);
        Console.WriteLine($"\nPoint A: ({pointA.X}, {pointA.Y})");
        Console.WriteLine($"Point B: ({pointB.X}, {pointB.Y})");
        Console.WriteLine($"Distance between points: {distance:F2}");
        
        Console.ReadKey();
    }
}
